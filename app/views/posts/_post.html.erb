<div id="<%= dom_id post %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Title:</strong>
    <%= post.title %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Caption:</strong>
    <%= post.caption %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Brightness:</strong>
    <%= post.brightness %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Contrast:</strong>
    <%= post.contrast %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Saturation:</strong>
    <%= post.saturation %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Filter name:</strong>
    <%= post.filter_name %>
  </div>
</div>
